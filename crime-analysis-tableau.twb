          <datasource-dependencies datasource='federated.06sjl5l032wgo71bfvfbc1jctf6v'>
            <column caption='growth' datatype='integer' name='[Calculation_489766472794787842]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [year] : SUM([TOTAL IPC CRIMES]) }' />
            </column>
            <column caption='Growth Rate' datatype='real' name='[Calculation_489766472795205635]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Calculation_489766472794787842]) - LOOKUP(SUM([Calculation_489766472794787842]), -1)) / LOOKUP(SUM([Calculation_489766472794787842]), -1) * 100'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='integer' name='[TOTAL IPC CRIMES]' role='measure' type='quantitative' />
            <column-instance column='[year]' derivation='None' name='[none:year:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_489766472795205635]' derivation='User' name='[usr:Calculation_489766472795205635:qk]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Rows' />
